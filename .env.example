# docker-compose.yml 에서 사용하는 환경 변수 예시.
# 운영 시 `cp .env.example .env` 후 실제 값으로 교체.
#
# 백엔드 애플리케이션의 상세 설정은 backend/.env 를 참고.

# ----- Postgres -----
POSTGRES_DB=kb_estate
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5433

# ----- Redis -----
REDIS_PORT=6379

# ----- 서비스 노출 포트 -----
BACKEND_PORT=8002
FRONTEND_PORT=5173
