# ----- Environment -----
# development | staging | production
ENVIRONMENT=development

# ----- Database -----
# 본 앱은 수집기와 동일 PostgreSQL을 공유 (ADR-002)
DATABASE_URL=postgresql://kb_user:kb_password@localhost:5433/kb_estate

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- API server -----
API_HOST=0.0.0.0
API_PORT=8002

# ----- CORS -----
# 콤마로 구분. 운영에서는 실제 도메인만 허용
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- JWT (Phase 1b에서 사용) -----
# 운영에서는 반드시 강한 랜덤값으로 교체. `openssl rand -hex 32` 등으로 생성
JWT_SECRET_KEY=change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ----- LLM / OpenAI (Phase 3에서 사용, ADR-008) -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_DAILY_CALL_LIMIT=1000

# ----- Logging / Observability -----
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# ----- Rate limiting -----
DEFAULT_RATE_LIMIT_PER_MINUTE=60

# ----- Object storage (Phase 2에서 첨부파일 도입 시) -----
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=newtech-uploads
