# API 서버 base URL.
# 개발(npm run dev): 빈 값 권장 — vite proxy가 /api 요청을 백엔드(8002)로 전달.
# 운영(빌드 산출물): 실제 API 도메인을 지정 (예: https://api.example.com)
VITE_API_BASE_URL=

# 유사물건 지도용 타일 URL.
# 운영망: OpenStreetMap 사용 (아래 두 줄 주석 해제)
# 폐쇄망: 빈 값 그대로 두면 타일 없이 점만 렌더 (회색 배경)
# VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>
