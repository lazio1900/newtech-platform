# 에이픽 인증키 (MD5)
APICK_AUTH_KEY=your_md5_auth_key_here

# 메인 백엔드와 공유할 내부 토큰 (X-Internal-Token 헤더로 전달)
INTERNAL_TOKEN=change_me_to_random_string

# 공유 PostgreSQL (newtech-platform 5433)
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5433/newtech

# 글로벌 킬 스위치
REGISTRY_ENABLED=true

# 비용 가드 (보수값)
DAILY_LIMIT=20
HOURLY_LIMIT=10
DUPLICATE_BLOCK_HOURS=24

# PDF 저장 경로
STORAGE_DIR=./storage/pdf

# 에이픽 호출 옵션
APICK_BASE_URL=https://apick.app
APICK_TIMEOUT=60
DOWNLOAD_POLL_INTERVAL=5
DOWNLOAD_POLL_MAX_TRIES=8
